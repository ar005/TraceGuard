<?xml version="1.0" encoding="utf-8"?>
<!-- Allow cleartext for development (plaintext gRPC to local backend).
     In production, set useCleartextTraffic="false" and enforce TLS. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
